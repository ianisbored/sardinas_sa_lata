@article{Balanay2009,
  title = {Exposure of {{Jeepney Drivers}} in {{Manila}}, {{Philippines}}, to {{Selected Volatile Organic Compounds}} ({{VOCs}})},
  author = {Balanay, Jo Anne G. and Lungu, Claudiu T.},
  year = 2009,
  journal = {Industrial Health},
  volume = {47},
  number = {1},
  pages = {33--42},
  issn = {0019-8366, 1880-8026},
  doi = {10.2486/indhealth.47.33},
  urldate = {2025-11-30},
  abstract = {The objective of this study was to assess the occupational exposure of jeepney drivers to selected volatile organic compounds (VOCs) in Manila, Philippines. Personal sampling was conducted on 15 jeepney drivers. Area sampling was conducted to determine the background VOC concentration in Manila as compared to that in a rural area. Both personal and area samples were collected for 5 working days. Samples were obtained using diffusive samplers and were analyzed for 6 VOCs (benzene, toluene, ethylbenzene, m,p-xylene and o-xylene) using gas chromatography. Results showed that the average personal exposure concentration of jeepney drivers was 55.6 (\textpm{} 9.3), 196.6 (\textpm{} 75.0), 17.9 (\textpm{} 9.0), 72.5 (\textpm{} 21.1) and 88.5 (\textpm{} 26.5) \textmu g/m3 for benzene, toluene, ethylbenzene, m,p-xylene and o-xylene, respectively. The urban ambient concentration was 11.8 (\textpm{} 2.2), 83.7 (\textpm{} 40.5) and 38.0 (\textpm{} 12.1) \textmu g/m3 for benzene, toluene and o-xylene, respectively. The rural ambient concentration was 14.0 (\textpm{} 6.0) and 24.7 (\textpm{} 11.9) \textmu g/m3 for toluene and o-xylene, respectively. The personal samples had significantly higher (p{$<$}0.05) concentrations for all selected VOCs than the urban area samples. Among the area samples, the urban concentrations of benzene and toluene were significantly higher (p{$<$}0.05) than the rural concentrations. The personal exposures for all the target VOCs were not significantly different among the jeepney drivers.},
  langid = {english},
  keywords = {Manlagnit,pollution},
  file = {C:\Users\ian\Zotero\storage\S6WM9D4M\Balanay and Lungu - 2009 - Exposure of Jeepney Drivers in Manila, Philippines, to Selected Volatile Organic Compounds (VOCs).pdf}
}

@article{Bastos2008,
