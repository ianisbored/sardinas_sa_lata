  author = {Beltran, Paula Mae and Consolacion, Ana Mae and De Guzman, Nicole Angelica and Endaya, Meca Ella and Escarpe, Edie Kyle and Licsi, Christian Louis and Ponio, Ellis Tristan and Ramos, Paula Mae and Subijano, Keana Pauline and Cruz, Hardie Gieben},
